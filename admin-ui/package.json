{
  "name": "@unchainedshop/admin-ui",
  "license": "EUPL-1.2",
  "version": "5.0.0-alpha.3",
  "description": "Unchained Commerce Admin UI Template",
  "main": "./out/index.html",
  "exports": {
    ".": "./out/index.html",
    "./ui": {
      "import": "./dist/ui.mjs",
      "types": "./dist/components/ui/index.d.ts"
    },
    "./form": {
      "import": "./dist/form.mjs",
      "types": "./dist/components/ui/form/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks.mjs",
      "types": "./dist/sdk/hooks.d.ts"
    },
    "./providers": {
      "import": "./dist/providers.mjs",
      "types": "./dist/sdk/providers.d.ts"
    },
    "./modal": {
      "import": "./dist/modal.mjs",
      "types": "./dist/sdk/modal.d.ts"
    },
    "./theme": "./src/sdk/theme.ts",
    "./plugins": "./src/sdk/plugins.ts",
    "./plugin-build": {
      "import": "./src/sdk/plugin-build.mjs"
    },
    "./tailwind-preset": {
      "import": "./src/sdk/tailwind-preset.mjs"
    },
    "./styles": "./src/styles/globals.css"
  },
  "files": [
    "dist",
    "out",
    "src/styles/globals.css"
  ],
  "scripts": {
    "prepublishOnly": "npm run build && npm run build:sdk",
    "dev": "next dev",
    "build": "NODE_ENV=production next build",
    "build:sdk": "tsup && tsc -p tsconfig.sdk.json",
    "start": "next start",
    "lint": "eslint .",
    "format": "eslint --fix .",
    "extract-translation": "formatjs extract 'src/(pages|modules|components)/**/*.{ts,tsx,jsx}' --out-file src/lang/en.json --id-interpolation-pattern '[sha512:contenthash:base64:6]'",
    "compile-translation": "formatjs compile  ./src/lang/en.json  --out-file ./src/i18n/en.json --format custom-formatter.cjs && node extract-missing-translation-keys.cjs",
    "build:client": "cd client && npm run build",
    "pack:client": "cd client && npm pack",
    "build:both": "npm run build && npm run build:client",
    "serve": "npx serve out",
    "cy:run": "cypress run",
    "cy:open": "cypress run",
    "test:e2e": "cypress run",
    "test:component": "cypress open --component",
    "test:e2e-record": "cypress run --browser chrome --record",
    "version:patch": "npm version patch && npm run tag",
    "version:minor": "npm version minor && npm run tag",
    "version:major": "npm version major && npm run tag",
    "tag": "git push --follow-tags",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "contributors": [
    "Vedran Rudelj <vedran@unchained.shop> (http://www.unchained.shop)",
    "Pascal Kaufmann <pascal@unchained.shop> (http://www.unchained.shop)",
    "Mikael Araya Mengistu <mikael@unchained.shop> (http://www.unchained.shop)"
  ],
  "devDependencies": {
    "@ai-sdk/react": "^3.0.14",
    "@apollo/client": "^4.0.11",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@eslint/js": "^10.0.0",
    "@formatjs/cli": "^6.8.1",
    "@formatjs/intl-pluralrules": "^6.0.1",
    "@formatjs/intl-relativetimeformat": "^12.0.2",
    "@graphql-codegen/cli": "^6.1.0",
    "@graphql-codegen/typescript-operations": "^5.0.6",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@next/eslint-plugin-next": "^16.0.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.7",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "ai": "^6.0.14",
    "clsx": "^2.1.1",
    "cypress": "^15.18.0",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "deepmerge": "^4.3.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.0.0",
    "eslint-plugin-formatjs": "^6.0.1",
    "eslint-plugin-prettier": "^5.5.4",
    "formik": "^2.4.9",
    "globals": "^17.0.0",
    "graphql": "^16.12.0",
    "intl-messageformat": "^11.0.1",
    "lodash.isequal": "^4.5.0",
    "lucide-react": "^1.7.0",
    "next": "^16.0.10",
    "npm-run-all": "^4.1.5",
    "papaparse": "^5.5.3",
    "prettier": "^3.7.4",
    "react": "19.2",
    "react-dom": "19.2",
    "react-intl": "^10.1.1",
    "react-is": "19.2",
    "react-markdown": "^10.1.0",
    "react-toastify": "^11.0.5",
    "recharts": "^3.6.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.12",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "validator": "^13.15.23"
  }
}
